{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "module": "esnext",
    "paths": {
      "@/*": ["./src/*"],
      "@components": ["./src/components"],
      "@constants": ["./src/constants"],
      "@functions": ["./src/functions"],
      "@hooks": ["./src/hooks"],
      "@store": ["./src/store"],
      "@theme": ["./src/theme"],
      "@formValidate": ["./src/formValidate"],
      "@api": ["./src/api"],
      "@types": ["./src/types"],
      "@routes": ["./src/routes"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
  "extends": "expo/tsconfig.base"
}
